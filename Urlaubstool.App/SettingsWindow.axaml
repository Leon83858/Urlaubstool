<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="Urlaubstool.App.SettingsWindow"
        Title="Einstellungen"
        Width="700"
        Height="650"
        WindowStartupLocation="CenterOwner"
        CanResize="False">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="30" Spacing="20">
            <TextBlock Text="Einstellungen" FontSize="24" FontWeight="Bold" />

            <!-- Personal Information -->
            <Border Classes="card">
                <StackPanel Spacing="12">
                    <TextBlock Text="Persönliche Angaben" FontWeight="Bold" FontSize="16" />
                    
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="150" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Vorname:" VerticalAlignment="Center" />
                        <TextBox Grid.Row="0" Grid.Column="1" x:Name="VornameTextBox" />

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Adresse:" VerticalAlignment="Center" Margin="0,8,0,0" />
                        <TextBox Grid.Row="1" Grid.Column="1" x:Name="AdresseTextBox" Margin="0,8,0,0" TextWrapping="NoWrap" AcceptsReturn="False" />

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Nachname:" VerticalAlignment="Center" Margin="0,8,0,0" />
                        <TextBox Grid.Row="2" Grid.Column="1" x:Name="NachnameTextBox" Margin="0,8,0,0" />

                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Abteilung:" VerticalAlignment="Center" Margin="0,8,0,0" />
                        <TextBox Grid.Row="3" Grid.Column="1" x:Name="AbteilungTextBox" Margin="0,8,0,0" />

                        <TextBlock Grid.Row="4" Grid.Column="0" Text="Personalnummer:" VerticalAlignment="Center" Margin="0,8,0,0" />
                        <TextBox Grid.Row="4" Grid.Column="1" x:Name="PersonalnummerTextBox" Margin="0,8,0,0" />

                        <TextBlock Grid.Row="5" Grid.Column="0" Text="Klasse:" VerticalAlignment="Center" Margin="0,8,0,0" />
                        <TextBox Grid.Row="5" Grid.Column="1" x:Name="KlasseTextBox" Margin="0,8,0,0" />

                        <TextBlock Grid.Row="6" Grid.Column="0" Text="Jahresurlaub (Tage):" VerticalAlignment="Center" Margin="0,8,0,0" />
                        <TextBox Grid.Row="6" Grid.Column="1" x:Name="JahresurlaubTextBox" Margin="0,8,0,0" />
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Export Settings -->
            <Border Classes="card">
                <StackPanel Spacing="12">
                    <TextBlock Text="Export-Einstellungen" FontWeight="Bold" FontSize="16" />
                    
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="150" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        
                        <TextBlock Grid.Column="0" Text="Export-Pfad:" VerticalAlignment="Center" />
                        <TextBox Grid.Column="1" x:Name="ExportPathTextBox" 
                                 Watermark="Standard: ~/Documents/Urlaubstool/Exports" 
                                 Margin="0,0,8,0" />
                        <Button Grid.Column="2" Content="Durchsuchen..." Click="BrowseExportPath_Click" />
                    </Grid>
                    
                    <TextBlock Classes="muted" Text="Leer lassen für Standard-Pfad" FontSize="11" />
                </StackPanel>
            </Border>

            <!-- Work Days -->
            <Border Classes="card">
                <StackPanel Spacing="12">
                    <TextBlock Text="Arbeitstage" FontWeight="Bold" FontSize="16" />
                    
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="150" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        
                        <TextBlock Grid.Column="0" Text="Bundesland:" VerticalAlignment="Center" />
                        <ComboBox Grid.Column="1" x:Name="BundeslandComboBox" />
                    </Grid>

                    <WrapPanel>
                        <CheckBox x:Name="MondayCheckBox" Content="Montag" Margin="0,0,15,8" />
                        <CheckBox x:Name="TuesdayCheckBox" Content="Dienstag" Margin="0,0,15,8" />
                        <CheckBox x:Name="WednesdayCheckBox" Content="Mittwoch" Margin="0,0,15,8" />
                        <CheckBox x:Name="ThursdayCheckBox" Content="Donnerstag" Margin="0,0,15,8" />
                        <CheckBox x:Name="FridayCheckBox" Content="Freitag" Margin="0,0,15,8" />
                        <CheckBox x:Name="SaturdayCheckBox" Content="Samstag" Margin="0,0,15,8" />
                        <CheckBox x:Name="SundayCheckBox" Content="Sonntag" Margin="0,0,15,8" />
                    </WrapPanel>
                </StackPanel>
            </Border>

            <!-- Student Parameters -->
            <Border Classes="card">
                <StackPanel Spacing="12">
                    <CheckBox x:Name="StudentActiveCheckBox" Content="Schülerparameter aktivieren" FontWeight="Bold" FontSize="14" />
                    
                    <StackPanel x:Name="StudentParametersPanel" Spacing="10">

                        <TextBlock Text="Berufsschultage:" FontWeight="SemiBold" Margin="0,10,0,5" />
                        <TextBlock Text="Für jeden Wochentag:" FontSize="12" Classes="muted" Margin="0,0,0,5" />
                        
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Montag:" VerticalAlignment="Center" />
                            <ComboBox Grid.Row="0" Grid.Column="1" x:Name="MondayVocCombo" Margin="0,2" />

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Dienstag:" VerticalAlignment="Center" />
                            <ComboBox Grid.Row="1" Grid.Column="1" x:Name="TuesdayVocCombo" Margin="0,2" />

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Mittwoch:" VerticalAlignment="Center" />
                            <ComboBox Grid.Row="2" Grid.Column="1" x:Name="WednesdayVocCombo" Margin="0,2" />

                            <TextBlock Grid.Row="3" Grid.Column="0" Text="Donnerstag:" VerticalAlignment="Center" />
                            <ComboBox Grid.Row="3" Grid.Column="1" x:Name="ThursdayVocCombo" Margin="0,2" />

                            <TextBlock Grid.Row="4" Grid.Column="0" Text="Freitag:" VerticalAlignment="Center" />
                            <ComboBox Grid.Row="4" Grid.Column="1" x:Name="FridayVocCombo" Margin="0,2" />

                            <TextBlock Grid.Row="5" Grid.Column="0" Text="Samstag:" VerticalAlignment="Center" />
                            <ComboBox Grid.Row="5" Grid.Column="1" x:Name="SaturdayVocCombo" Margin="0,2" />

                            <TextBlock Grid.Row="6" Grid.Column="0" Text="Sonntag:" VerticalAlignment="Center" />
                            <ComboBox Grid.Row="6" Grid.Column="1" x:Name="SundayVocCombo" Margin="0,2" />
                        </Grid>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Color Settings -->
            <Border Classes="card">
                <StackPanel Spacing="12">
                    <TextBlock Text="Farb-Einstellungen (HEX-Codes)" FontWeight="Bold" FontSize="16" />
                    
                    <!-- Row 1: Ganztägiger Schultag -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="200" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="50" />
                            <ColumnDefinition Width="100" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Ganztägiger Schultag:" VerticalAlignment="Center" />
                        <TextBox Grid.Column="1" x:Name="ColorSchultagGanztag" Watermark="z.B. #FFCDD2" Margin="0,0,8,0" TextChanged="OnColorTextChanged" />
                        <Border Grid.Column="2" x:Name="ColorSchultagGanztagPreview" Margin="0,0,8,0" CornerRadius="3" BorderBrush="#88888888" BorderThickness="1" />
                        <Button Grid.Column="3" Content="Reset" Click="ResetColorSchultagGanztag_Click" />
                    </Grid>

                    <!-- Row 2: Wochenende/Feiertag -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="200" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="50" />
                            <ColumnDefinition Width="100" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Wochenende/Feiertag:" VerticalAlignment="Center" />
                        <TextBox Grid.Column="1" x:Name="ColorWochenende" Watermark="z.B. #C8E6C9" Margin="0,0,8,0" TextChanged="OnColorTextChanged" />
                        <Border Grid.Column="2" x:Name="ColorWochenendePreview" Margin="0,0,8,0" CornerRadius="3" BorderBrush="#88888888" BorderThickness="1" />
                        <Button Grid.Column="3" Content="Reset" Click="ResetColorWochenende_Click" />
                    </Grid>

                    <!-- Row 3: Halbtägiger Schultag -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="200" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="50" />
                            <ColumnDefinition Width="100" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Halbtägiger Schultag:" VerticalAlignment="Center" />
                        <TextBox Grid.Column="1" x:Name="ColorSchultagHalbtag" Watermark="z.B. #FFE0B2" Margin="0,0,8,0" TextChanged="OnColorTextChanged" />
                        <Border Grid.Column="2" x:Name="ColorSchultagHalbtag_Preview" Margin="0,0,8,0" CornerRadius="3" BorderBrush="#88888888" BorderThickness="1" />
                        <Button Grid.Column="3" Content="Reset" Click="ResetColorSchultagHalbtag_Click" />
                    </Grid>

                    <!-- Row 4: Genehmigter Urlaub -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="200" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="50" />
                            <ColumnDefinition Width="100" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Genehmigter Urlaub:" VerticalAlignment="Center" />
                        <TextBox Grid.Column="1" x:Name="ColorGenehmigterUrlaub" Watermark="z.B. #E1BEE7" Margin="0,0,8,0" TextChanged="OnColorTextChanged" />
                        <Border Grid.Column="2" x:Name="ColorGenehmigterUrlaubPreview" Margin="0,0,8,0" CornerRadius="3" BorderBrush="#88888888" BorderThickness="1" />
                        <Button Grid.Column="3" Content="Reset" Click="ResetColorGenehmigterUrlaub_Click" />
                    </Grid>

                    <!-- Row 5: Normaltag -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="200" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="50" />
                            <ColumnDefinition Width="100" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Normaltag:" VerticalAlignment="Center" />
                        <TextBox Grid.Column="1" x:Name="ColorNormaltag" Watermark="z.B. #0E1A2D" Margin="0,0,8,0" TextChanged="OnColorTextChanged" />
                        <Border Grid.Column="2" x:Name="ColorNormaltagPreview" Margin="0,0,8,0" CornerRadius="3" BorderBrush="#88888888" BorderThickness="1" />
                        <Button Grid.Column="3" Content="Reset" Click="ResetColorNormaltag_Click" />
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Validation Error -->
            <TextBlock x:Name="ValidationErrorTextBlock" 
                       Foreground="Red" 
                       FontWeight="Bold"
                       TextWrapping="Wrap"
                       IsVisible="False" />

            <!-- Buttons -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="10">
                <Button Content="Abbrechen" Width="120" x:Name="CancelButton" Click="Cancel_Click" />
                <Button Content="Speichern" Width="120" x:Name="SaveButton" Click="Save_Click" 
                        Background="#1976D2" Foreground="White" FontWeight="Bold" />
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</Window>
