<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Urlaubstool.App.ViewModels"
        xmlns:local="using:Urlaubstool.App"
        xmlns:controls="using:Urlaubstool.App.Controls"
        x:Class="Urlaubstool.App.MainWindow"
        Title="Urlaubstool"
        Width="970"
        Height="800"
        WindowStartupLocation="CenterScreen"
        ShowInTaskbar="True"
        CanResize="True">

    <Window.Resources>
    </Window.Resources>

    <Design.DataContext>
        <vm:MainWindowViewModel />
    </Design.DataContext>

    <DockPanel>
        <!-- Menu Bar -->
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="Datei">
                <MenuItem Header="Beenden" Click="Exit_Click" />
            </MenuItem>
            <MenuItem Header="Einstellungen" Click="Settings_Click" />
        </Menu>

        <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="20" Spacing="15">
            <!-- Header -->
            <StackPanel>
                <TextBlock Text="Urlaubsantrag" FontSize="28" FontWeight="Bold" />
                <TextBlock x:Name="UserInfoTextBlock" FontSize="14" Classes="muted" Margin="0,5,0,0" />
            </StackPanel>

            <!-- Summary -->
            <Border Classes="card">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Jahresurlaub" FontSize="12" Classes="muted" />
                        <TextBlock x:Name="EntitlementTextBlock" FontSize="20" FontWeight="Bold" />
                    </StackPanel>

                    <StackPanel Grid.Column="1">
                        <TextBlock Text="Beantragt" FontSize="12" Classes="muted" />
                        <TextBlock x:Name="RequestedDaysTextBlock" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource Brush.Accent}" />
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Genehmigt" FontSize="12" Classes="muted" />
                        <TextBlock x:Name="ApprovedDaysTextBlock" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource Brush.Success}" />
                    </StackPanel>

                    <StackPanel Grid.Column="3">
                        <TextBlock Text="Resturlaub" FontSize="12" Classes="muted" />
                        <TextBlock x:Name="RemainingDaysTextBlock" FontSize="20" FontWeight="Bold" Foreground="{Binding RemainingDaysColor}" />
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Date Selection -->
            <Border Classes="card">
                <StackPanel Spacing="12">
                    <TextBlock Text="Zeitraum" FontWeight="Bold" FontSize="16" />
                    
                    <!-- Date range buttons -->
                    <Grid ColumnDefinitions="1*,Auto,1*" RowDefinitions="Auto,Auto">
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Anreise:" VerticalAlignment="Center" FontSize="13" />
                        <Button Grid.Row="0" Grid.Column="0" x:Name="StartDateButton" 
                                Content="Datum auswählen..."
                                Click="StartDateButton_Click"
                                HorizontalAlignment="Stretch"
                                FontWeight="Bold"
                                Background="{DynamicResource Brush.Control}" 
                                Margin="0,0,8,0" />
                        
                        <TextBlock Grid.Row="0" Grid.Column="2" Text="Abreise:" VerticalAlignment="Center" FontSize="13" Margin="8,0,0,0" />
                        <Button Grid.Row="0" Grid.Column="2" x:Name="EndDateButton" 
                                Content="Datum auswählen..."
                                Click="EndDateButton_Click"
                                HorizontalAlignment="Stretch"
                                FontWeight="Bold"
                                Background="{DynamicResource Brush.Control}"
                                Margin="8,0,0,0" />

                        <!-- Validation Errors -->
                        <TextBlock Grid.Row="1" Grid.Column="0" Foreground="{DynamicResource Brush.Danger}" FontSize="11" 
                                   Text="{Binding StartDateError}"
                                   IsVisible="{Binding StartDateError, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" 
                                   Margin="0,2,8,0" />
                        <TextBlock Grid.Row="1" Grid.Column="2" Foreground="{DynamicResource Brush.Danger}" FontSize="11" 
                                   Text="{Binding EndDateError}"
                                   IsVisible="{Binding EndDateError, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                   Margin="8,2,0,0" />
                    </Grid>

                    <!-- Half Day Selection -->
                    <StackPanel Spacing="8" Margin="0,8,0,0">
                        <CheckBox x:Name="StartHalfDayCheckBox" 
                                  Content="Halber Tag (Anreise)" 
                                  FontSize="13" />
                        <CheckBox x:Name="EndHalfDayCheckBox" 
                                  Content="Halber Tag (Abreise)" 
                                  FontSize="13" />
                    </StackPanel>

                    <!-- AZA-Tage Section -->
                    <Border BorderBrush="{DynamicResource Brush.Border}" BorderThickness="1" 
                            Padding="12" CornerRadius="6" Background="{DynamicResource Brush.Surface}" Margin="0,10,0,0">
                        <StackPanel Spacing="10">
                            <CheckBox x:Name="HasAzaDaysCheckBox" Content="Im Urlaubszeitraum sind AZA-Tage" 
                                      FontWeight="SemiBold" />
                            <StackPanel x:Name="AzaDaysPanel" IsVisible="False" Spacing="8">
                                <TextBlock Text="Wähle die AZA-Tage aus - für diese Tage werden keine Urlaubstage abgezogen:" 
                                           FontSize="12" Classes="muted" TextWrapping="Wrap" />
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <DatePicker x:Name="AzaNewDatePicker" HorizontalAlignment="Left" MinWidth="180" />
                                    <Button x:Name="AddAzaDateButton" Content="+ Hinzufügen" Width="140" Click="AddAzaDate_Click" />
                                </StackPanel>

                                <!-- Chips / tags for existing AZA dates -->
                                <ItemsControl x:Name="AzaDaysItemsControl" Margin="0,8,0,0" ItemsSource="{Binding AzaDays}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border BorderBrush="{DynamicResource Brush.Border}" BorderThickness="1" 
                                                    Padding="6" Margin="3" CornerRadius="16" Background="{DynamicResource Brush.Surface}">
                                                <StackPanel Orientation="Horizontal" Spacing="8">
                                                    <TextBlock Text="{Binding Date, StringFormat='{}{0:dd.MM.yyyy}'}" VerticalAlignment="Center" />
                                                    <Button Content="✗" Command="{Binding RemoveCommand}" Width="28" Height="24" />
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="10">
                        <Button Content="Aufschlüsselung" Width="130" x:Name="DayBreakdownButton" 
                            Click="ShowDayBreakdown_Click"
                            FontWeight="Bold"/>

                        <Button Content="PDF exportieren" Width="180" x:Name="ExportButton" 
                            Click="Export_Click"
                            FontWeight="Bold"/>

                        <TextBlock x:Name="ExportStatusTextBlock" VerticalAlignment="Center" Margin="8,0,0,0" Classes="muted" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Error Message -->
            <Border x:Name="ErrorBorder" BorderBrush="{DynamicResource Brush.Danger}" BorderThickness="2" Padding="12" 
                    CornerRadius="8" Background="{DynamicResource Brush.Surface}" IsVisible="False">
                <Grid ColumnDefinitions="*,Auto">
                    <TextBlock x:Name="ErrorTextBlock" Foreground="{DynamicResource Brush.Danger}" FontWeight="Bold" 
                               TextWrapping="Wrap" VerticalAlignment="Center" />
                    <Button Grid.Column="1" Content="Details" x:Name="ErrorDetailsButton" 
                            Click="ShowDayBreakdown_Click" Width="80" />
                </Grid>
            </Border>

            <!-- History Overview -->
            <Border Classes="card">
                <StackPanel Spacing="10">
                    <Grid ColumnDefinitions="Auto,*,Auto,Auto,Auto,Auto,Auto">
                        <TextBlock Text="Urlaubshistorie" FontWeight="Bold" FontSize="16" VerticalAlignment="Center" />
                        
                        <!-- Filters -->
                         <TextBlock Grid.Column="2" Text="Jahr:" VerticalAlignment="Center" Margin="0,0,10,0"/>
                         <NumericUpDown Grid.Column="3" Value="{Binding HistoryFilterYear}" Minimum="2020" Maximum="2030" Width="120"/>
                         
                         <!-- Status Filter -->
                         <ComboBox Grid.Column="4" SelectedIndex="{Binding HistoryFilterStatusIndex}" Margin="10,0,0,0" Width="160">
                            <ComboBoxItem Content="Alle" />
                            <ComboBoxItem Content="Exportiert" />
                            <ComboBoxItem Content="Genehmigt" />
                            <ComboBoxItem Content="Abgelehnt" />
                            <ComboBoxItem Content="Archiviert" />
                         </ComboBox>

                         <!-- Sort Filter -->
                         <ComboBox Grid.Column="5" SelectedIndex="{Binding HistorySortIndex}" Margin="10,0,0,0" Width="180">
                            <ComboBoxItem Content="Datum (früheste zuerst)" />
                            <ComboBoxItem Content="Datum (späteste zuerst)" />
                            <ComboBoxItem Content="Erstellt (neueste zuerst)" />
                            <ComboBoxItem Content="Status" />
                         </ComboBox>
                         
                         <Button Grid.Column="6" Content="↻" Margin="10,0,0,0" Command="{Binding RefreshHistoryCommand}"/>
                    </Grid>
                    
                    <DataGrid x:Name="HistoryDataGrid" 
                              Height="300"
                              AutoGenerateColumns="False"
                              IsReadOnly="False"
                              GridLinesVisibility="All"
                              CanUserReorderColumns="False"
                              CanUserResizeColumns="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Anfangsdatum" Binding="{Binding StartDateString}" Width="Auto" IsReadOnly="True" />
                            <DataGridCheckBoxColumn Header="Halbtag" Binding="{Binding StartHalfDay}" Width="Auto" IsReadOnly="True" />
                            <DataGridTextColumn Header="Enddatum" Binding="{Binding EndDateString}" Width="Auto" IsReadOnly="True" />
                            <DataGridCheckBoxColumn Header="Halbtag" Binding="{Binding EndHalfDay}" Width="Auto" IsReadOnly="True" />
                            <DataGridTextColumn Header="Tage" Binding="{Binding DaysString}" Width="Auto" IsReadOnly="True" />
                            <DataGridTextColumn Header="AZA Datum" Binding="{Binding AzaDatesString}" Width="Auto" IsReadOnly="True" />
                            <DataGridTextColumn Header="Status" Binding="{Binding StatusString}" Width="Auto" IsReadOnly="True" />
                            <DataGridTemplateColumn Header="Aktionen" Width="Auto">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" Spacing="5">
                                            <Button Content="📄 PDF" 
                                                    Command="{Binding OpenPdfCommand}"
                                                    IsEnabled="{Binding HasPdf}"
                                                    Padding="8,4"
                                                    FontSize="11" />
                                            <Button Content="✓" 
                                                    Command="{Binding ApproveCommand}"
                                                    IsEnabled="{Binding CanApprove}"
                                                    Background="#4CAF50" 
                                                    Foreground="White"
                                                    Padding="8,4"
                                                    FontSize="11" 
                                                    ToolTip.Tip="Genehmigen"/>
                                                <Button Content="✖" 
                                                    Command="{Binding RejectCommand}"
                                                    IsEnabled="{Binding CanApprove}"
                                                    Background="#F57C00"
                                                    Foreground="White"
                                                    Padding="8,4"
                                                    FontSize="11"
                                                    ToolTip.Tip="Ablehnen (mit Grund)" />
                                            <Button Content="📦" 
                                                    Command="{Binding ArchiveCommand}"
                                                    IsEnabled="{Binding CanArchive}"
                                                    Padding="8,4"
                                                    FontSize="11" 
                                                    ToolTip.Tip="Archivieren"/>
                                            <Button Content="✗" 
                                                    Command="{Binding DeleteCommand}"
                                                    Background="#f44336" 
                                                    Foreground="White"
                                                    Padding="8,4"
                                                    FontSize="11" 
                                                    ToolTip.Tip="Löschen (mit Bestätigung)"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </StackPanel>
            </Border>
        </StackPanel>
        </ScrollViewer>
    </DockPanel>
</Window>
